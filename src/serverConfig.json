      "modules": [
        { "id": "input_gateway", "type": "Input_Gateway", "position": [-2, 2.3, 0], "connections": ["threat_lab"] },
        { "id": "threat_lab", "type": "Threat_Lab", "position": [-0.7, 2.3, 0], "connections": ["clean_zone"] },
