      "cables": [
        { "from": "generator", "to": "ats_switch", "type": "power", "color": "#ff6600" },
        { "from": "ats_switch", "to": "smart_pdu", "type": "power", "color": "#ff6600", "targetLevel": 3 }
      ]
    },
    {
