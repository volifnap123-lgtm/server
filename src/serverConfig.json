    { "from": "part_a_inbound", "to": "input_gateway", "targetLevel": 1, "type": "data", "color": "#00aaff" },
    { "from": "outbound_control", "to": "container_factory", "targetLevel": 4, "type": "data", "color": "#aa00ff" }
