        { "id": "lifepo4_bank", "type": "LiFePO4_Bank", "position": [-1.5, 0.3, 0], "connections": [] },
        { "id": "generator", "type": "Generator", "subtype": "Hydrogen", "position": [0, 0.3, 0], "connections": ["ats_switch"] },
        { "id": "ats_switch", "type": "ATS_Switch", "position": [1.5, 0.3, 0], "connections": ["smart_pdu"] }
