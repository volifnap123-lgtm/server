        { "id": "climate_controller", "type": "Climate_Controller", "position": [-0.5, 6.3, 0], "connections": ["resource_arbiter"] },
        { "id": "resource_arbiter", "type": "Resource_Arbiter", "position": [0.5, 6.3, 0], "connections": ["admin_terminal_port"] },
        { "id": "admin_terminal_port", "type": "Admin_Terminal_Port", "position": [1.5, 6.3, 0], "connections": [] },
        { "id": "super_capacitor_bank", "type": "Super_Capacitor_Bank", "position": [-1.5, 6.3, 1.2], "connections": [] },
        { "id": "audit_box_3", "type": "Audit_Box", "position": [1.5, 6.3, 1.2], "connections": [] }
